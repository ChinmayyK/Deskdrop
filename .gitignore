# Rust build artifacts
target/
**/*.rs.bk
Cargo.lock   # libraries don't commit lock — binaries do

# macOS
.DS_Store
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM
platforms/macos/build/

# Windows
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
platforms/windows/**/bin/
platforms/windows/**/obj/
*.msi

# Android
*.apk
*.aab
*.ap_
*.dex
platforms/android/.gradle/
platforms/android/app/build/
platforms/android/local.properties

# Linux
*.deb
*.rpm

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets / keys — never commit these
*.pem
*.key
*.p12
*.pfx
trust.json
settings.json

# Logs
*.log
proxiboard-*.log

# Benchmark HTML output (large)
target/criterion/

# SBOM output (generated by CI)
bom.json

.cargo/

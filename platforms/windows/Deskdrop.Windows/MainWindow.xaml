<Window x:Class="Deskdrop.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Deskdrop.Windows"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Deskdrop" Height="680" Width="420"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        AllowDrop="True" DragEnter="Grid_DragEnter" DragLeave="Grid_DragLeave" Drop="Grid_Drop">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="32" CornerRadius="12" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Modern Fluid - Light Mode Colors -->
        <SolidColorBrush x:Key="BrandElectric" Color="#0055CC"/>
        <SolidColorBrush x:Key="BrandViolet" Color="#5E5CE6"/>
        <SolidColorBrush x:Key="BrandCyan" Color="#32ADE6"/>
        <SolidColorBrush x:Key="SurfaceElevated" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceStrong" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceGlass" Color="#E6FFFFFF"/> <!-- 90% white -->
        <SolidColorBrush x:Key="Ink" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="InkSoft" Color="#8E8E93"/>
        <SolidColorBrush x:Key="InkSubtle" Color="#C7C7CC"/>
        <SolidColorBrush x:Key="Stroke" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="StrokeSoft" Color="#F2F2F7"/>
        
        <SolidColorBrush x:Key="AppBackground" Color="#F2F2F7"/>

        <!-- Styles -->
        <Style x:Key="NavbarButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="16" Padding="16,8" Margin="4,0" Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A000000"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceElevated}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Stroke}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource InkSoft}"/>
        </Style>

        <Style x:Key="AnimatedCardStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                            <Border x:Name="border" Width="44" Height="24" CornerRadius="12" Background="{StaticResource Stroke}" Padding="2" VerticalAlignment="Center">
                                <Ellipse x:Name="thumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="4" ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandElectric}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceElevated}"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrandElectric}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandElectric}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0055A4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#004488"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4" Background="#33000000" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Style="{StaticResource ModernScrollBar}" HorizontalAlignment="Right" Minimum="0" Maximum="{TemplateBinding ScrollableHeight}" Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" CornerRadius="12" Background="{StaticResource SurfaceElevated}" Margin="0,0,0,12" Padding="16,16" BorderThickness="1" BorderBrush="{StaticResource Stroke}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animations -->
        <Storyboard x:Key="FadeInTransition">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,-20" To="0" Duration="0:0:0.35">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <Storyboard x:Key="ToastSlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,-20,0,0" To="0,16,0,0" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <Storyboard x:Key="ToastSlideOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.2"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,16,0,0" To="0,-20,0,0" Duration="0:0:0.2">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- Main Container -->
    <Border CornerRadius="16" BorderThickness="1" ClipToBounds="True"
            BorderBrush="{StaticResource Stroke}"
            Background="{StaticResource AppBackground}">
        <Grid>
            <!-- Sleek UI Architecture -->
            <Grid>
                <!-- Custom Title Bar -->
                <Grid Height="40" VerticalAlignment="Top" Background="Transparent" Panel.ZIndex="10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Image Source="pack://application:,,,/Assets/logo.png" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Deskdrop" Foreground="{StaticResource Ink}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button AutomationProperties.Name="Diagnostics" Content="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="NavDiagnostics_Click"/>
                        <Button AutomationProperties.Name="Minimize window" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="BtnMinimize_Click"/>
                        <Button AutomationProperties.Name="Close window" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Floating Nav Bar -->
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,32" CornerRadius="24" Background="{StaticResource SurfaceGlass}" BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" Padding="6" Panel.ZIndex="100">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="24" ShadowDepth="12" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="NavBtnHome" GroupName="NavGroup" Style="{StaticResource NavbarButtonStyle}" ToolTip="Timeline" IsChecked="True" Click="NavHome_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Timeline" FontSize="13" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtnDevices" GroupName="NavGroup" Style="{StaticResource NavbarButtonStyle}" ToolTip="Ecosystem" Margin="6,0,0,0" Click="NavDevices_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE975;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Ecosystem" FontSize="13" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtnTransfers" GroupName="NavGroup" Style="{StaticResource NavbarButtonStyle}" ToolTip="Transfers" Margin="6,0,0,0" Click="NavTransfers_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Transfers" FontSize="13" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavBtnSettings" GroupName="NavGroup" Style="{StaticResource NavbarButtonStyle}" ToolTip="Settings" Margin="6,0,0,0" Click="NavSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Settings" FontSize="13" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
</Border>

                <!-- Views Container -->
                <Grid Margin="0,40,0,0" AllowDrop="True" Drop="Grid_Drop" DragEnter="Grid_DragEnter" DragLeave="Grid_DragLeave">
                    
                    <!-- ========================================== -->
                    <!-- TRANSFERS VIEW                             -->
                    <!-- ========================================== -->
                    <Grid x:Name="TransfersView" Visibility="Collapsed" Margin="24,16,24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="Transfers" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                            <TextBlock Text="Manage active files and view recent history" FontSize="14" Foreground="{StaticResource InkSoft}" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="ACTIVE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource InkSoft}" Opacity="0.6" Margin="0,0,0,16"/>
                                <ItemsControl x:Name="ActiveTransfersList" Margin="0,0,0,32">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Background="{StaticResource SurfaceElevated}" Margin="0,0,0,12" Padding="16" BorderThickness="1" BorderBrush="{StaticResource StrokeSoft}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="40" Height="40" CornerRadius="20" Background="{StaticResource SurfaceStrong}" Margin="0,0,16,0" Grid.Column="0">
                                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource InkSoft}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource Ink}"/>
                                                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource InkSoft}" FontSize="12" Margin="0,4,0,0"/>
                                                        <ProgressBar Value="{Binding Percent}" Maximum="100" Height="4" Margin="0,8,0,0" Foreground="{Binding ProgressColor}" Background="{StaticResource SurfaceStrong}" BorderThickness="0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <Button Content="{Binding ActionIcon1}" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="28" Height="28" Background="{StaticResource SurfaceStrong}" Foreground="{Binding ActionColor1}" BorderThickness="0" Margin="0,0,8,0" Command="{Binding ActionCommand1}"/>
                                                        <Button Content="{Binding ActionIcon2}" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="28" Height="28" Background="{StaticResource SurfaceStrong}" Foreground="{Binding ActionColor2}" BorderThickness="0" Command="{Binding ActionCommand2}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <TextBlock Text="RECENT HISTORY" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource InkSoft}" Opacity="0.6" Margin="0,0,0,16"/>
                                <ItemsControl x:Name="TransfersHistoryList" Margin="0,0,0,32">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonDown="TransferHistoryItem_Click">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource InkSoft}" Opacity="0.8" Width="32" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Summary}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource Ink}"/>
                                                    <TextBlock Text="{Binding Source}" Foreground="{StaticResource InkSoft}" FontSize="12" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding RelativeTime}" FontSize="12" Foreground="{StaticResource InkSoft}" Opacity="0.6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource BrandElectric}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- ========================================== -->
                    <!-- HOME VIEW                                  -->
                    <!-- ========================================== -->
                    <Grid x:Name="HomeView" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="48,24,48,24" Grid.Row="0">
                            <Grid Margin="0,0,0,32">
                                <!-- Quick Actions Ribbon -->
                                <ScrollViewer x:Name="QuickActionsRibbon" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource ModernButton}" Background="{StaticResource SurfaceElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="16,12" Margin="0,0,12,0" Click="BorderPushClipboard_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource BrandElectric}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Sync Clipboard" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ModernButton}" Background="{StaticResource SurfaceElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="16,12" Margin="0,0,12,0" Click="BorderSendFiles_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8D5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource BrandViolet}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Send Files" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ModernButton}" Background="{StaticResource SurfaceElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="16,12" Margin="0,0,12,0" Click="BorderStreamCamera_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource BrandCyan}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Stream Camera" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ModernButton}" Background="{StaticResource SurfaceElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="16,12" Margin="0,0,12,0" Click="BorderBroadcastCamera_Click" x:Name="BorderBroadcastCameraBtn">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF3B30" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="TxtBroadcastTitle" Text="Broadcast Camera" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <!-- Onboarding Checklist -->
                                <Border x:Name="OnboardingGrid" Visibility="Collapsed" Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="Welcome to Deskdrop" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,16"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock x:Name="Step1Icon" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource BrandElectric}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Step1Text" Text="Step 1: Find a nearby device" Foreground="{StaticResource Ink}" VerticalAlignment="Center" FontSize="14"/>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock x:Name="Step2Icon" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource Stroke}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Step2Text" Text="Step 2: Connect and trust a device" Foreground="{StaticResource InkSoft}" VerticalAlignment="Center" FontSize="14"/>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <TextBlock x:Name="Step3Icon" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource Stroke}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Step3Text" Text="Step 3: Ready to use!" Foreground="{StaticResource InkSoft}" VerticalAlignment="Center" FontSize="14"/>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button x:Name="BtnSkipOnboarding" Content="Skip for now" Style="{StaticResource ModernButton}" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Click="BtnDismissOnboarding_Click" Margin="0,0,12,0"/>
                                            <Button x:Name="BtnDismissOnboarding" Visibility="Collapsed" Content="Get Started" Style="{StaticResource ModernButton}" Click="BtnDismissOnboarding_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Quick Context Strip -->
                                <Border x:Name="QuickContextStrip" Visibility="Collapsed" Background="{StaticResource AppBackground}" CornerRadius="12" BorderBrush="{StaticResource BrandElectric}" BorderThickness="1" Padding="20" Margin="0,0,0,32">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="JUST COPIED" FontSize="12" FontWeight="Bold" Foreground="#32ADE6" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtQuickContext" Text="Clipboard text preview" Foreground="{StaticResource Ink}" FontSize="14" FontFamily="Consolas" MaxHeight="60" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,0,0,16"/>
                                        <Button Content="Send to All Devices" Style="{StaticResource ModernButton}" Click="BtnSendQuickContext_Click"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                            
                            <TextBlock Text="Activity" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                            <TextBlock Text="Your clipboard history" FontSize="16" Foreground="{StaticResource InkSoft}" Margin="0,8,0,0"/>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1" Margin="48,0,48,48">
                            <ItemsControl x:Name="TimelineList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="16" Background="{StaticResource SurfaceElevated}" Margin="0,0,0,16" Padding="20" BorderThickness="1" BorderBrush="{StaticResource StrokeSoft}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="16" ShadowDepth="4"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Left accent stripe -->
                                                <Border Width="3" CornerRadius="1.5" Background="{StaticResource BrandElectric}" Margin="-20,-20,16,-20" HorizontalAlignment="Left"/>
                                                
                                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource SurfaceStrong}" Margin="12,0,16,0" Grid.Column="0">
                                                    <TextBlock Text="{Binding TypeIcon}" FontSize="18" Foreground="{StaticResource BrandElectric}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Summary}" Foreground="{StaticResource Ink}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Source}" Foreground="{StaticResource InkSoft}" FontSize="13" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding RelativeTime}" Foreground="{StaticResource InkSubtle}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                    <Button Content="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="16" Background="Transparent" Foreground="{Binding PinColor}" BorderThickness="0" Margin="0,0,8,0" Cursor="Hand" Click="BtnPinItem_Click" ToolTip="Pin to top"/>
                                                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Background="Transparent" Foreground="#FF3B30" BorderThickness="0" Cursor="Hand" Click="BtnDeleteItem_Click" ToolTip="Delete"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Devices View -->
                    <Grid x:Name="DevicesView" Visibility="Collapsed" Background="{StaticResource AppBackground}">
                        <StackPanel Margin="48,24,48,48">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Background="Transparent" Foreground="{StaticResource Ink}" BorderThickness="0" Padding="0,0,16,0" Click="BtnBack_Click"/>
                                <TextBlock Text="Ecosystem" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                            </StackPanel>
                            <TextBlock Text="Nearby devices" FontSize="16" Foreground="{StaticResource InkSoft}" Margin="0,8,0,32"/>
                            
                            <ItemsControl x:Name="DevicesList" Margin="0,0,0,32">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="16" Background="{StaticResource SurfaceElevated}" Margin="0,0,0,16" Padding="20" BorderThickness="1" BorderBrush="{StaticResource StrokeSoft}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="16" ShadowDepth="4"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="52" Height="52" CornerRadius="26" Background="{StaticResource BrandElectric}" Opacity="0.1" Margin="0,0,16,0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <Border Width="52" Height="52" CornerRadius="26" BorderBrush="{StaticResource BrandElectric}" BorderThickness="1" Margin="0,0,16,0" Grid.Column="0">
                                                    <TextBlock Text="&#xE975;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{StaticResource BrandElectric}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding friendly_name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                                    <TextBlock Text="{Binding status}" Foreground="{StaticResource InkSoft}" FontSize="13" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Style="{StaticResource ModernButton}" Content="Disconnect" Background="#FFF0F0" Foreground="#FF3B30" Padding="20,10" Tag="{Binding device_id}" Click="BtnDisconnectDevice_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <TextBlock Text="Manual Connect (Magic Link)" FontSize="18" Foreground="{StaticResource Ink}" FontWeight="Bold" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtConnectAddress" Style="{StaticResource ModernTextBox}" Grid.Column="0" Margin="0,0,12,0" Text="192.168.1.x:47823"/>
                                <Button Content="Connect" Style="{StaticResource ModernButton}" Grid.Column="1" Click="BtnConnect_Click" Margin="0,0,12,0"/>
                                <Button Content="Show QR Code" Style="{StaticResource ModernButton}" Grid.Column="2" Background="#2C2C2E" Foreground="{StaticResource Ink}" Click="BtnShowQR_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Settings View -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed" Background="{StaticResource AppBackground}">
                        <ScrollViewer>
                            <StackPanel Margin="48,24,48,48">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                    <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Background="Transparent" Foreground="{StaticResource Ink}" BorderThickness="0" Padding="0,0,16,0" Click="BtnBack_Click"/>
                                    <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                </StackPanel>
                                
                                <!-- General -->
                                <TextBlock Text="General" Foreground="{StaticResource BrandElectric}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>
                                <Border Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="20">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkLaunchOnStartup" Style="{StaticResource ToggleSwitchStyle}" Content="Launch Deskdrop on Windows startup" Margin="0,0,0,20"/>
                                        <CheckBox x:Name="ChkSyncEnabled" Style="{StaticResource ToggleSwitchStyle}" Content="Enable clipboard syncing" Margin="0,0,0,20"/>
                                        <CheckBox x:Name="ChkSyncText" Style="{StaticResource ToggleSwitchStyle}" Content="Sync text" Margin="24,0,0,16"/>
                                        <CheckBox x:Name="ChkSyncImages" Style="{StaticResource ToggleSwitchStyle}" Content="Sync images" Margin="24,0,0,16"/>
                                        <CheckBox x:Name="ChkSyncFiles" Style="{StaticResource ToggleSwitchStyle}" Content="Sync files" Margin="24,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Privacy -->
                                <TextBlock Text="Privacy &amp; Security" Foreground="{StaticResource BrandElectric}" FontSize="14" FontWeight="Bold" Margin="0,32,0,16"/>
                                <Border Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="20">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkShowNotifications" Style="{StaticResource ToggleSwitchStyle}" Content="Show notifications on receive" Margin="0,0,0,20"/>
                                        <CheckBox x:Name="ChkRequireTofu" Style="{StaticResource ToggleSwitchStyle}" Content="Require confirmation for new devices"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Network -->
                                <TextBlock Text="Network" Foreground="{StaticResource BrandElectric}" FontSize="14" FontWeight="Bold" Margin="0,32,0,16"/>
                                <Border Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="20" Margin="0,0,0,24">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Device Name" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtDeviceName" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                                    </Grid>
                                </Border>
                                
                                <Button Content="Save Settings" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Padding="24,12" Click="BtnSaveSettings_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Diagnostics View -->
                    <Grid x:Name="DiagnosticsView" Visibility="Collapsed" Background="{StaticResource AppBackground}">
                        <ScrollViewer>
                            <StackPanel Margin="48,24,48,48">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                    <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Background="Transparent" Foreground="{StaticResource Ink}" BorderThickness="0" Padding="0,0,16,0" Click="BtnBack_Click"/>
                                    <TextBlock Text="Diagnostics" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                </StackPanel>

                                <StackPanel>
                                    <Border CornerRadius="12" Background="{StaticResource SurfaceElevated}" Padding="20" BorderThickness="1" BorderBrush="{StaticResource Stroke}" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource BrandElectric}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Daemon Status" FontWeight="SemiBold" Foreground="{StaticResource Ink}" FontSize="16"/>
                                                <TextBlock x:Name="TxtDiagDaemonStatus" Text="Checking..." Foreground="{StaticResource InkSoft}" Margin="0,4,0,4"/>
                                                <TextBlock x:Name="TxtDiagDaemonSuggestion" Text="If stopped, please restart the tray app." Foreground="{StaticResource InkSubtle}" FontSize="12" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <Button x:Name="BtnRestartConnection" Grid.Column="2" Content="Restart App" Style="{StaticResource ModernButton}" VerticalAlignment="Center" Click="BtnRestartConnection_Click"/>
                                        </Grid>
                                    </Border>

                                    <Border CornerRadius="12" Background="{StaticResource SurfaceElevated}" Padding="20" BorderThickness="1" BorderBrush="{StaticResource Stroke}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE124;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource BrandElectric}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Local Network" FontWeight="SemiBold" Foreground="{StaticResource Ink}" FontSize="16"/>
                                                <TextBlock x:Name="TxtDiagNetworkStatus" Text="Looking for peers" Foreground="{StaticResource InkSoft}" Margin="0,4,0,4"/>
                                                <TextBlock x:Name="TxtDiagNetworkSuggestion" Text="Ensure devices are on the same Wi-Fi network." Foreground="{StaticResource InkSubtle}" FontSize="12" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <Button x:Name="BtnScanAgain" Grid.Column="2" Content="Scan Again" Style="{StaticResource ModernButton}" VerticalAlignment="Center" Click="BtnScanAgain_Click"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                
                <!-- Inline Notification Toast Overlay -->
                <Border x:Name="NotificationToast" CornerRadius="8" Background="{StaticResource SurfaceElevated}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Margin="0,16,0,0" Padding="16,12" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed" Panel.ZIndex="50" MinWidth="300">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="4"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NotificationIcon" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource BrandElectric}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBlock x:Name="NotificationMessage" Text="Settings saved." Foreground="{StaticResource Ink}" FontSize="14" VerticalAlignment="Center" Grid.Column="1" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Tofu Prompt Overlay -->
                <Grid x:Name="TofuPromptOverlay" Visibility="Collapsed" Panel.ZIndex="100">
                    <Border Background="#99000000" />
                    <Border Background="{StaticResource SurfaceElevated}" CornerRadius="16" BorderBrush="{StaticResource Stroke}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32" MaxWidth="500">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.6" BlurRadius="40" ShadowDepth="10" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Trust new device?" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,16"/>
                            <TextBlock Text="A new device wants to sync your clipboard." Foreground="{StaticResource InkSoft}" FontSize="16" Margin="0,0,0,24"/>
                            
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" CornerRadius="24" Background="#2C2C2E" Margin="0,0,16,0" Grid.Column="0">
                                    <TextBlock Text="&#xE975;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource BrandElectric}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtTofuDeviceName" Text="DeviceName" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Fingerprint:" Foreground="{StaticResource InkSubtle}" FontSize="14" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtTofuFingerprint" Style="{StaticResource ModernTextBox}" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" MinHeight="80" MaxHeight="120" Margin="0,0,0,24"/>

                            <TextBlock Text="&#xE783; Only trust devices you own or control." FontFamily="Segoe MDL2 Assets" Foreground="DarkOrange" FontSize="14" Margin="0,0,0,24" TextWrapping="Wrap"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="&#xE8FB; Trust" FontFamily="Segoe MDL2 Assets" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="BtnTofuTrust_Click"/>
                                <Button Grid.Column="1" Content="&#xE711; Reject" FontFamily="Segoe MDL2 Assets" Style="{StaticResource ModernButton}" Background="#FFF0F0" Foreground="#FF3B30" Margin="8,0,0,0" Click="BtnTofuReject_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Drop Zone Overlay -->
                <Grid x:Name="DropZoneOverlay" Visibility="Collapsed" Panel.ZIndex="999" Background="{StaticResource SurfaceGlass}">
                    <Border CornerRadius="24" BorderBrush="{StaticResource BrandElectric}" BorderThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="48" Background="{StaticResource SurfaceElevated}">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource BrandElectric}}" BlurRadius="40" Opacity="0.5" ShadowDepth="0"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="100" Height="100" Margin="0,0,0,24" HorizontalAlignment="Center">
                                <Border CornerRadius="50" Background="{StaticResource BrandElectric}" Opacity="0.1"/>
                                <Rectangle RadiusX="50" RadiusY="50" Stroke="{StaticResource BrandElectric}" StrokeThickness="2" StrokeDashArray="2 2" Fill="Transparent"/>
                                <TextBlock Text="&#xE8D5;" FontFamily="Segoe MDL2 Assets" FontSize="40" Foreground="{StaticResource BrandElectric}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Drop to Send" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Sends to all connected devices" FontSize="14" Foreground="{StaticResource InkSubtle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

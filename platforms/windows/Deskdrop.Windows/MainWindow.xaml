<Window x:Class="Deskdrop.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Deskdrop.Windows"
        Title="Deskdrop" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="32" CornerRadius="12" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Minimalist Void - Dark Mode Colors -->
        <SolidColorBrush x:Key="BrandElectric" Color="#0066CC"/>
        <SolidColorBrush x:Key="BrandViolet" Color="#5E5CE6"/>
        <SolidColorBrush x:Key="BrandCyan" Color="#32ADE6"/>
        <SolidColorBrush x:Key="SurfaceElevated" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="SurfaceStrong" Color="#2C2C2E"/>
        <SolidColorBrush x:Key="Surface" Color="#121212"/>
        <SolidColorBrush x:Key="Ink" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InkSoft" Color="#EBEBF5"/>
        <SolidColorBrush x:Key="InkSubtle" Color="#8E8E93"/>
        <SolidColorBrush x:Key="Stroke" Color="#38383A"/>
        
        <SolidColorBrush x:Key="AppBackground" Color="#000000"/>

        <!-- Styles -->
        <Style x:Key="NavbarButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="16" Padding="16,8" Margin="4,0" Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C1C1E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#38383A"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource InkSoft}"/>
        </Style>

        <Style x:Key="AnimatedCardStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                            <Border x:Name="border" Width="44" Height="24" CornerRadius="12" Background="#38383A" Padding="2" VerticalAlignment="Center">
                                <Ellipse x:Name="thumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="4" ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrandElectric}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1C1C1E"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrandElectric}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandElectric}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0055A4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#004488"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4" Background="#33FFFFFF" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Style="{StaticResource ModernScrollBar}" HorizontalAlignment="Right" Minimum="0" Maximum="{TemplateBinding ScrollableHeight}" Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" CornerRadius="12" Background="{StaticResource SurfaceElevated}" Margin="0,0,0,12" Padding="16,16" BorderThickness="1" BorderBrush="{StaticResource Stroke}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container -->
    <Border CornerRadius="16" BorderThickness="1" ClipToBounds="True">
        <Border.BorderBrush>
            <SolidColorBrush Color="#222222"/>
        </Border.BorderBrush>
        <Border.Background>
            <SolidColorBrush Color="{StaticResource AppBackground}"/>
        </Border.Background>
        <Grid>
            <!-- Sleek UI Architecture -->
            <Grid>
                <!-- Custom Title Bar -->
                <Grid Height="40" VerticalAlignment="Top" Background="Transparent" Panel.ZIndex="10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Image Source="pack://application:,,,/Assets/logo.png" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Deskdrop" Foreground="{StaticResource Ink}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="NavSettings_Checked"/>
                        <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="BtnMinimize_Click"/>
                        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Views Container -->
                <Grid Margin="0,40,0,0">
                    
                    <!-- Home View -->
                    <Grid x:Name="HomeView" Visibility="Visible">
                        <StackPanel Margin="48,24,48,48">
                            <TextBlock Text="Actions" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,8"/>
                            <TextBlock Text="Quick tools for your ecosystem" FontSize="16" Foreground="{StaticResource InkSoft}" Margin="0,0,0,32"/>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="180"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Push Clipboard Card -->
                                <Border Style="{StaticResource AnimatedCardStyle}" Grid.Row="0" Grid.Column="0" Background="#111111" CornerRadius="20" Padding="24" Margin="0,0,12,12" MouseLeftButtonDown="BorderPushClipboard_Click" Cursor="Hand" BorderThickness="1" BorderBrush="#222222">
                                    <StackPanel Background="Transparent">
                                        <Border Width="48" Height="48" CornerRadius="24" Background="#1C1C1E" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource BrandElectric}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Clipboard Sync" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Send copied text &amp; images" Foreground="{StaticResource InkSoft}" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Send Files Card -->
                                <Border Style="{StaticResource AnimatedCardStyle}" Grid.Row="0" Grid.Column="1" Background="#111111" CornerRadius="20" Padding="24" Margin="12,0,0,12" MouseLeftButtonDown="BorderSendFiles_Click" Cursor="Hand" BorderThickness="1" BorderBrush="#222222">
                                    <StackPanel Background="Transparent">
                                        <Border Width="48" Height="48" CornerRadius="24" Background="#1C1C1E" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE8D5;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource BrandViolet}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Files" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Share files across devices" Foreground="{StaticResource InkSoft}" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Stream Camera Card -->
                                <Border Style="{StaticResource AnimatedCardStyle}" Grid.Row="1" Grid.Column="0" Background="#111111" CornerRadius="20" Padding="24" Margin="0,12,12,0" MouseLeftButtonDown="BorderStreamCamera_Click" Cursor="Hand" BorderThickness="1" BorderBrush="#222222">
                                    <StackPanel Background="Transparent">
                                        <Border Width="48" Height="48" CornerRadius="24" Background="#1C1C1E" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource BrandCyan}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Stream Camera" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
                                        <TextBlock Text="View connected camera feed" Foreground="{StaticResource InkSoft}" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Broadcast Camera Card -->
                                <Border Style="{StaticResource AnimatedCardStyle}" Grid.Row="1" Grid.Column="1" Background="#111111" CornerRadius="20" Padding="24" Margin="12,12,0,0" MouseLeftButtonDown="BorderBroadcastCamera_Click" Cursor="Hand" x:Name="BorderBroadcastCamera" BorderThickness="1" BorderBrush="#222222">
                                    <StackPanel Background="Transparent">
                                        <Border Width="48" Height="48" CornerRadius="24" Background="#1C1C1E" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#FF3B30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="TxtBroadcastTitle" Text="Broadcast Camera" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtBroadcastDesc" Text="Push local webcam to peers" Foreground="{StaticResource InkSoft}" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Timeline View -->
                    <Grid x:Name="TimelineView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="48,24,48,24">
                            <TextBlock Text="Activity" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                            <TextBlock Text="Your clipboard history" FontSize="16" Foreground="{StaticResource InkSoft}" Margin="0,8,0,0"/>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1" Margin="48,0,48,48">
                            <ItemsControl x:Name="TimelineList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="16" Background="#1C1C1E" Margin="0,0,0,16" Padding="20" BorderThickness="1" BorderBrush="#38383A">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="44" Height="44" CornerRadius="22" Background="#2C2C2E" Margin="0,0,16,0" Grid.Column="0">
                                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource BrandElectric}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Summary}" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Source}" Foreground="{StaticResource InkSoft}" FontSize="14" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding RelativeTime}" Foreground="{StaticResource InkSubtle}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Devices View -->
                    <Grid x:Name="DevicesView" Visibility="Collapsed">
                        <StackPanel Margin="48,24,48,48">
                            <TextBlock Text="Ecosystem" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                            <TextBlock Text="Nearby devices" FontSize="16" Foreground="{StaticResource InkSoft}" Margin="0,8,0,32"/>
                            
                            <ItemsControl x:Name="DevicesList" Margin="0,0,0,32">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="16" Background="#1C1C1E" Margin="0,0,0,16" Padding="20" BorderThickness="1" BorderBrush="#38383A">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="52" Height="52" CornerRadius="26" Background="#2C2C2E" Margin="0,0,16,0" Grid.Column="0">
                                                    <TextBlock Text="&#xE975;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{StaticResource Ink}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding friendly_name}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                                    <TextBlock Text="{Binding status}" Foreground="{StaticResource InkSoft}" FontSize="14" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Style="{StaticResource ModernButton}" Content="Disconnect" Background="#2C1A1A" Foreground="#FF3B30" Padding="20,10" Tag="{Binding device_id}" Click="BtnDisconnectDevice_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <TextBlock Text="Manual Connect (Magic Link)" FontSize="18" Foreground="{StaticResource Ink}" FontWeight="Bold" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtConnectAddress" Style="{StaticResource ModernTextBox}" Grid.Column="0" Margin="0,0,12,0" Text="192.168.1.x:47823"/>
                                <Button Content="Connect" Style="{StaticResource ModernButton}" Grid.Column="1" Click="BtnConnect_Click" Margin="0,0,12,0"/>
                                <Button Content="Show QR Code" Style="{StaticResource ModernButton}" Grid.Column="2" Background="#2C2C2E" Foreground="{StaticResource Ink}" Click="BtnShowQR_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Settings View -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed">
                        <ScrollViewer>
                            <StackPanel Margin="48,24,48,48">
                                <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                <TextBlock Text="Deskdrop Preferences" FontSize="16" Foreground="{StaticResource InkSoft}" Margin="0,8,0,32"/>
                                
                                <!-- General -->
                                <TextBlock Text="General" Foreground="{StaticResource BrandElectric}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>
                                <Border Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="20">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkSyncEnabled" Style="{StaticResource ToggleSwitchStyle}" Content="Enable clipboard syncing" Margin="0,0,0,20"/>
                                        <CheckBox x:Name="ChkSyncText" Style="{StaticResource ToggleSwitchStyle}" Content="Sync text" Margin="24,0,0,16"/>
                                        <CheckBox x:Name="ChkSyncImages" Style="{StaticResource ToggleSwitchStyle}" Content="Sync images" Margin="24,0,0,16"/>
                                        <CheckBox x:Name="ChkSyncFiles" Style="{StaticResource ToggleSwitchStyle}" Content="Sync files" Margin="24,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Privacy -->
                                <TextBlock Text="Privacy &amp; Security" Foreground="{StaticResource BrandElectric}" FontSize="14" FontWeight="Bold" Margin="0,32,0,16"/>
                                <Border Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="20">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkShowNotifications" Style="{StaticResource ToggleSwitchStyle}" Content="Show notifications on receive" Margin="0,0,0,20"/>
                                        <CheckBox x:Name="ChkRequireTofu" Style="{StaticResource ToggleSwitchStyle}" Content="Require confirmation for new devices"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Network -->
                                <TextBlock Text="Network" Foreground="{StaticResource BrandElectric}" FontSize="14" FontWeight="Bold" Margin="0,32,0,16"/>
                                <Border Background="{StaticResource SurfaceElevated}" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="20" Margin="0,0,0,24">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Device Name" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtDeviceName" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                                    </Grid>
                                </Border>
                                
                                <Button Content="Save Settings" Style="{StaticResource ModernButton}" HorizontalAlignment="Left" Padding="24,12" Click="BtnSaveSettings_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                
                <!-- Floating Navigation Bar -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,32" CornerRadius="24" Background="#1C1C1E" BorderThickness="1" Padding="8" Panel.ZIndex="20">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#38383A"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.50" BlurRadius="32" ShadowDepth="16" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="Nav" Style="{StaticResource NavbarButtonStyle}" IsChecked="True" Checked="NavHome_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Home" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Nav" Style="{StaticResource NavbarButtonStyle}" Checked="NavTimeline_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Activity" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Nav" Style="{StaticResource NavbarButtonStyle}" Checked="NavDevices_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE975;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>

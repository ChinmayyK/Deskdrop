<Window x:Class="Deskdrop.Windows.QRPairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Magic Link Pair" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Stroke" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="Ink" Color="#111111"/>
        <SolidColorBrush x:Key="InkSoft" Color="#6E6E73"/>
    </Window.Resources>

    <Border Background="{StaticResource AppBackground}" CornerRadius="16" BorderBrush="{StaticResource Stroke}" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="20" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Grid>
            <!-- Title Bar for Dragging -->
            <Grid Height="40" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="Window_MouseDown" Panel.ZIndex="10">
                <Button   FontSize="10" Width="40" Height="30" HorizontalAlignment="Right" Background="Transparent" Foreground="{StaticResource InkSoft}" BorderThickness="0" Click="BtnClose_Click"><iconPacks:PackIconLucide Kind="X"/></Button>
            </Grid>

            <Grid Margin="32,48,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Magic Link Pair" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="1" Text="Scan the QR code below from the Deskdrop Android app to pair instantly." 
                           Foreground="{StaticResource InkSoft}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,32"/>
                
                <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Image x:Name="ImgQRCode" Width="200" Height="200" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>


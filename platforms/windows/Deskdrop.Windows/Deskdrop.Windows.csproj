<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Deskdrop</AssemblyName>
    <Company>Deskdrop</Company>
    <Product>Deskdrop</Product>
    <Version>0.1.0</Version>
    <Description>Proximity-Based Shared Clipboard</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Native Rust DLL built by cargo build (release) -->
    <None Include="..\..\..\deskdrop-core\target\release\deskdrop_core.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="QRCoder" Version="1.4.3" />
  </ItemGroup>
</Project>

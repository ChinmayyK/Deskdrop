<Window x:Class="Deskdrop.Windows.DropZoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drop Files Here" Height="1080" Width="1920"
        WindowStyle="None" AllowsTransparency="True" Background="#90000000"
        Topmost="True" ShowInTaskbar="False" WindowState="Maximized"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" Loaded="Window_Loaded">
    <Grid>
        <Border x:Name="DropBorder" BorderBrush="#32ADE6" BorderThickness="4" CornerRadius="20" 
                Margin="100" Background="#4032ADE6" Opacity="0.5">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📁" FontSize="120" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Drop files anywhere to send" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Click anywhere to cancel" Foreground="#AAAAAA" FontSize="20" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

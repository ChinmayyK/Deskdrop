# Deskdrop systemd user service
#
# Install: install -Dm644 deskdrop.service ~/.config/systemd/user/deskdrop.service
#           systemctl --user daemon-reload
#           systemctl --user enable --now deskdrop
#
# Logs:    journalctl --user -u deskdrop -f
# Status:  systemctl --user status deskdrop

[Unit]
Description=Deskdrop — Proximity-Based Shared Clipboard
Documentation=https://github.com/deskdrop/deskdrop
# Network must be available before we start (mDNS discovery won't work otherwise).
After=network-online.target
Wants=network-online.target
# Restart after graphical session is available so clipboard access works.
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/local/bin/deskdrop-gtk
Restart=on-failure
RestartSec=5s
# Give the process up to 10 s to start responding before systemd considers it failed.
TimeoutStartSec=10s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=deskdrop

# ── Resource limits ────────────────────────────────────────────────────────────
MemoryMax=128M
MemoryHigh=96M
CPUQuota=15%
# Cap file descriptors — we open one socket per peer connection.
LimitNOFILE=1024

# ── State persistence ──────────────────────────────────────────────────────────
# Engine persists trust store, identity key, and peer store here.
# Resolves to ~/.local/share/deskdrop (user service).
StateDirectory=deskdrop
# Runtime dir for the IPC socket.
RuntimeDirectory=deskdrop

# ── Security hardening ─────────────────────────────────────────────────────────
NoNewPrivileges=true
# Home dir must be readable for clipboard watcher (arboard reads XDG_RUNTIME_DIR).
ProtectHome=true
ProtectSystem=strict
PrivateTmp=true
PrivateDevices=true
# mDNS uses multicast; restrict to required address families.
RestrictAddressFamilies=AF_INET AF_INET6 AF_NETLINK AF_UNIX
# Prevent kernel module loading.
RestrictModules=true
# No SUID/SGID files.
RestrictSUIDSGID=true
# Lock down system calls.
SystemCallFilter=@system-service @network-io @file-system
SystemCallErrorNumber=EPERM
# Prevent access to other users' data.
PrivateUsers=true
# Prevent writing to /proc or /sys.
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
# Clipboard access requires the user's session bus.
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=%t/bus
Environment=DESKDROP_LOG=info
Environment=RUST_BACKTRACE=0
# State and runtime paths for the engine.
Environment=DESKDROP_STATE_DIR=%S/deskdrop
Environment=DESKDROP_RUNTIME_DIR=%t/deskdrop

[Install]
WantedBy=default.target
